# Asterisk AMI creds (must match manager.conf)
AMI_USERNAME=admin
AMI_PASSWORD=troque-por-senha-ami

# Public API URL consumed by Next.js frontend (must be public HTTPS URL)
NEXT_PUBLIC_API_URL=https://api.seudominio.com
