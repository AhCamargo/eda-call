# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_DB=edacall
POSTGRES_USER=edacall
POSTGRES_PASSWORD=troque-por-senha-forte

# ── Backend ───────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-jwt-forte
INTERNAL_API_KEY=troque-por-chave-interna

# ── Asterisk AMI (deve coincidir com manager.conf) ────────────────────────────
AMI_USERNAME=admin
AMI_PASSWORD=troque-por-senha-ami

# ── Asterisk — IP público do VPS (para NAT/SDP) ───────────────────────────────
ASTERISK_EXTERN_IP=SEU_IP_PUBLICO_DO_VPS

# ── Registro SIP no tronco (opcional) ────────────────────────────────────────
# Formato: usuario:senha@host:porta
ASTERISK_EFIX_REGISTER=

# ── Frontend — URL pública da API (HTTPS) ─────────────────────────────────────
VITE_API_URL=https://api.seudominio.com
