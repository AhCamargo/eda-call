POSTGRES_DB=edacall
POSTGRES_USER=edacall
POSTGRES_PASSWORD=edacall
POSTGRES_PORT=5432

BACKEND_PORT=5000
JWT_SECRET=          # OBRIGATÓRIO — gere com: openssl rand -hex 32
ADMIN_PASSWORD=troque-esta-senha-antes-de-usar
LOG_DIR=/edacall-logs
INTERNAL_API_KEY=    # RECOMENDADO — gere com: openssl rand -hex 16

AMI_HOST=asterisk
AMI_PORT=5038
AMI_USERNAME=        # OBRIGATÓRIO — usuário definido no manager.conf do Asterisk
AMI_PASSWORD=        # OBRIGATÓRIO — senha definida no manager.conf do Asterisk
ASTERISK_SIP_CUSTOM_FILE=/asterisk-config/sip_custom.conf
ASTERISK_RECORDINGS_DIR=/asterisk-recordings
ASTERISK_SOUNDS_DIR=/asterisk-sounds
BACKEND_INTERNAL_URL=http://backend:5000

FRONTEND_PORT=5173
NEXT_PUBLIC_API_URL=http://localhost:5000
