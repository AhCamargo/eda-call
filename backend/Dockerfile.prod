FROM node:22-alpine AS builder

RUN apk upgrade --no-cache

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .
RUN npx tsc

# ── Runtime ──────────────────────────────────────────────────────────────────
FROM node:22-alpine

RUN apk upgrade --no-cache

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev

COPY --from=builder /app/dist ./dist

ENV NODE_ENV=production
EXPOSE 5000

CMD ["node", "dist/server.js"]
