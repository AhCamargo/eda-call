# ── EdaCall Monitor — Configuração do Servidor de Monitoramento ───────────────
# Copie para .env e preencha os valores antes de rodar: cp .env.example .env

# ── Banco de dados (Zabbix) ───────────────────────────────────────────────────
ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=troque_esta_senha_forte

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=troque_esta_senha_forte
GRAFANA_ROOT_URL=http://SEU_IP_OU_DOMINIO:3000

# ── Geral ─────────────────────────────────────────────────────────────────────
TIMEZONE=America/Sao_Paulo
