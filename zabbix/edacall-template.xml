<?xml version="1.0" encoding="UTF-8"?>
<!--
  EdaCall — Zabbix Template
  ═══════════════════════════════════════════════════════
  Versão : 1.0
  Compatível com: Zabbix 6.0 LTS ou superior

  Importar em:
    Zabbix → Configuration → Templates → Import

  Após importar:
    1. Crie um Host para cada servidor cliente
    2. Vincule este template ao host
    3. Configure a macro {$EDACALL_API} se necessário
       (padrão: http://localhost:5000)

  Pré-requisitos no servidor do cliente:
    - Zabbix Agent 2 instalado e rodando
    - /usr/local/bin/edacall-license-status instalado e com permissão de execução
    - /etc/zabbix/zabbix_agent2.d/userparameter_edacall.conf instalado
═══════════════════════════════════════════════════════ -->
<zabbix_export>
  <version>6.0</version>
  <date>2026-05-23T00:00:00Z</date>

  <groups>
    <group>
      <uuid>a571c0d144b14fd4a87a9d9b2aa9fcd6</uuid>
      <name>EdaCall</name>
    </group>
  </groups>

  <templates>
    <template>
      <uuid>b4e2c3d1a5f748e9b2c1d3e4f5a6b7c8</uuid>
      <template>Template EdaCall PABX</template>
      <name>Template EdaCall PABX</name>
      <description>Monitoramento de licença e saúde do sistema EdaCall PABX</description>
      <groups>
        <group>
          <name>EdaCall</name>
        </group>
      </groups>

      <!-- ── Macros ─────────────────────────────────────────────────────── -->
      <macros>
        <macro>
          <macro>{$EDACALL_LICENSE_WARN_DAYS}</macro>
          <value>30</value>
          <description>Dias antes do vencimento para disparar alerta de aviso</description>
        </macro>
        <macro>
          <macro>{$EDACALL_LICENSE_CRIT_DAYS}</macro>
          <value>7</value>
          <description>Dias antes do vencimento para disparar alerta crítico</description>
        </macro>
      </macros>

      <!-- ── Items ─────────────────────────────────────────────────────── -->
      <items>

        <!-- Status geral: 1 = válida, 0 = inválida -->
        <item>
          <uuid>c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6</uuid>
          <name>EdaCall: Status da licença</name>
          <key>edacall.license.valid</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>UNSIGNED</value_type>
          <delay>5m</delay>
          <history>90d</history>
          <description>1 = licença válida, 0 = inválida ou expirada</description>
          <valuemap>
            <name>EdaCall License Status</name>
          </valuemap>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- Dias restantes -->
        <item>
          <uuid>d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7</uuid>
          <name>EdaCall: Dias restantes na licença</name>
          <key>edacall.license.days_remaining</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>1h</delay>
          <history>90d</history>
          <description>Dias até expiração. "null" = vitalício, "-1" = API indisponível</description>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- Nome do cliente -->
        <item>
          <uuid>e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8</uuid>
          <name>EdaCall: Nome do cliente</name>
          <key>edacall.license.client_name</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>1h</delay>
          <history>30d</history>
          <description>Nome da empresa/cliente vinculado à licença</description>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- ID do cliente -->
        <item>
          <uuid>f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9</uuid>
          <name>EdaCall: ID do cliente</name>
          <key>edacall.license.client_id</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>1h</delay>
          <history>30d</history>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- Data de expiração -->
        <item>
          <uuid>a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0</uuid>
          <name>EdaCall: Data de expiração da licença</name>
          <key>edacall.license.expires_at</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>1h</delay>
          <history>30d</history>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- Máximo de ramais -->
        <item>
          <uuid>b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1</uuid>
          <name>EdaCall: Máximo de ramais SIP</name>
          <key>edacall.license.max_extensions</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>1h</delay>
          <history>30d</history>
          <description>Limite de ramais SIP. 0 = ilimitado</description>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- Licença expirada? -->
        <item>
          <uuid>c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2</uuid>
          <name>EdaCall: Licença expirada</name>
          <key>edacall.license.expired</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>5m</delay>
          <history>90d</history>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- Mensagem de erro -->
        <item>
          <uuid>d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3</uuid>
          <name>EdaCall: Erro de licença</name>
          <key>edacall.license.error</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>TEXT</value_type>
          <delay>5m</delay>
          <history>30d</history>
          <description>Mensagem de erro quando a licença é inválida. Vazio = licença OK</description>
          <tags>
            <tag><tag>component</tag><value>license</value></tag>
          </tags>
        </item>

        <!-- API health check via HTTP -->
        <item>
          <uuid>e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4</uuid>
          <name>EdaCall: API disponível</name>
          <key>net.tcp.service[http,,5000]</key>
          <type>ZABBIX_ACTIVE</type>
          <value_type>UNSIGNED</value_type>
          <delay>1m</delay>
          <history>30d</history>
          <description>1 = API respondendo na porta 5000, 0 = fora do ar</description>
          <tags>
            <tag><tag>component</tag><value>api</value></tag>
          </tags>
        </item>

      </items>

      <!-- ── Triggers ──────────────────────────────────────────────────── -->
      <triggers>

        <!-- Licença inválida / bloqueada -->
        <trigger>
          <uuid>f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5</uuid>
          <expression>last(/Template EdaCall PABX/edacall.license.valid)=0</expression>
          <name>EdaCall: Licença INVÁLIDA em {HOST.NAME}</name>
          <priority>DISASTER</priority>
          <description>A licença EdaCall está inválida ou expirada. O sistema pode estar bloqueado. Cliente: {ITEM.VALUE:/Template EdaCall PABX/edacall.license.client_name}</description>
          <tags>
            <tag><tag>scope</tag><value>license</value></tag>
          </tags>
        </trigger>

        <!-- Licença expirando em breve — CRÍTICO -->
        <trigger>
          <uuid>a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6</uuid>
          <expression><![CDATA[last(/Template EdaCall PABX/edacall.license.valid)=1 and last(/Template EdaCall PABX/edacall.license.days_remaining)<>{$EDACALL_LICENSE_CRIT_DAYS} and last(/Template EdaCall PABX/edacall.license.days_remaining)<>"null" and last(/Template EdaCall PABX/edacall.license.days_remaining)>="0" and last(/Template EdaCall PABX/edacall.license.days_remaining)<="{$EDACALL_LICENSE_CRIT_DAYS}"]]></expression>
          <name>EdaCall: Licença expira em {ITEM.VALUE:/Template EdaCall PABX/edacall.license.days_remaining} dias em {HOST.NAME}</name>
          <priority>HIGH</priority>
          <description>A licença EdaCall expira em menos de {$EDACALL_LICENSE_CRIT_DAYS} dias. Renove imediatamente!</description>
          <tags>
            <tag><tag>scope</tag><value>license</value></tag>
          </tags>
        </trigger>

        <!-- Licença expirando em breve — AVISO -->
        <trigger>
          <uuid>b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7</uuid>
          <expression><![CDATA[last(/Template EdaCall PABX/edacall.license.valid)=1 and last(/Template EdaCall PABX/edacall.license.days_remaining)<>"null" and last(/Template EdaCall PABX/edacall.license.days_remaining)>"{$EDACALL_LICENSE_CRIT_DAYS}" and last(/Template EdaCall PABX/edacall.license.days_remaining)<="{$EDACALL_LICENSE_WARN_DAYS}"]]></expression>
          <name>EdaCall: Licença expira em {ITEM.VALUE:/Template EdaCall PABX/edacall.license.days_remaining} dias em {HOST.NAME}</name>
          <priority>WARNING</priority>
          <description>A licença EdaCall expira em menos de {$EDACALL_LICENSE_WARN_DAYS} dias.</description>
          <tags>
            <tag><tag>scope</tag><value>license</value></tag>
          </tags>
        </trigger>

        <!-- API fora do ar -->
        <trigger>
          <uuid>c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8</uuid>
          <expression>last(/Template EdaCall PABX/net.tcp.service[http,,5000])=0</expression>
          <name>EdaCall: API indisponível em {HOST.NAME}</name>
          <priority>HIGH</priority>
          <description>A API do EdaCall (porta 5000) não está respondendo.</description>
          <tags>
            <tag><tag>scope</tag><value>availability</value></tag>
          </tags>
        </trigger>

      </triggers>

      <!-- ── Value Maps ────────────────────────────────────────────────── -->
      <valuemaps>
        <valuemap>
          <uuid>d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9</uuid>
          <name>EdaCall License Status</name>
          <mappings>
            <mapping>
              <value>0</value>
              <newvalue>INVÁLIDA</newvalue>
            </mapping>
            <mapping>
              <value>1</value>
              <newvalue>VÁLIDA</newvalue>
            </mapping>
          </mappings>
        </valuemap>
      </valuemaps>

    </template>
  </templates>

</zabbix_export>
